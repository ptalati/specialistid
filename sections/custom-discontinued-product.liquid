{% style %}
  .discontinued-product {
    background-color: #f4f4f4;
    padding: 20px;
    border: 1px solid #ccc;
    margin-top: 20px;
    display: flex;
    gap: 10px;
  }

  .discontinued-text {
    font-size: 18px;
    color: #d9534f; /* Red color for discontinued text */
    margin: 0 0 0 0;
  }

  .discontinued-product img {
    max-width: 100%;
    width: 120px;
    height: auto;
    display: block;
    margin-top: 0px;
  }
  a.button--primary.discontinued {
    background-color: grey !important;
  }
  a.button--primary.discontinued:after {
    box-shadow: none !important;
  }
  a.button--primary.discontinued:before {
    background-color: grey !important;
  }
{% endstyle %}

{% if product.metafields.c_f.discontinued != blank %}
  {% if section.settings.discontinued_text != blank or section.settings.discontinued_img != blank %}
    <div class="discontinued-product page-width">
      {% if section.settings.discontinued_img != blank %}
        <img src="{{ section.settings.discontinued_img | img_url: 'medium' }}" alt="Discontinued Product Image">
      {% endif %}

      {% if section.settings.discontinued_text != blank %}
        <div class="discontinued-content">
          <p class="discontinued-text">{{ section.settings.discontinued_text }}</p>

          {% assign discontinued_raw = product.metafields.c_f.discontinued | string | strip %}
          {% assign discontinued_value = discontinued_raw | downcase %}
          {% if discontinued_value != 'true' and discontinued_raw != blank %}
            {% assign replacement_url = blank %}
            {% assign replacement_title = blank %}
            {% assign replacement_handle = blank %}
            {% assign replacement_product = product.metafields.c_f.discontinued.value %}

            {% if replacement_product != blank %}
              {% if replacement_product.url != blank %}
                {% assign replacement_url = replacement_product.url %}
              {% endif %}
              {% if replacement_product.title != blank %}
                {% assign replacement_title = replacement_product.title %}
              {% endif %}
            {% endif %}

            {% if replacement_url == blank %}
              {% assign replacement_url = discontinued_raw %}
            {% endif %}

            {% if replacement_url contains '/products/' %}
              {% assign replacement_handle = replacement_url | split: '/products/' | last | split: '?' | first | split: '#' | first %}
            {% else %}
              {% assign has_scheme = false %}
              {% assign has_slash = false %}
              {% if discontinued_raw contains '://' %}
                {% assign has_scheme = true %}
              {% endif %}
              {% if discontinued_raw contains '/' %}
                {% assign has_slash = true %}
              {% endif %}
              {% if has_scheme == false and has_slash == false %}
                {% assign replacement_handle = discontinued_raw %}
              {% endif %}
            {% endif %}

            {% if replacement_title == blank and replacement_handle != blank %}
              {% assign replacement_lookup = all_products[replacement_handle] %}
              {% if replacement_lookup != blank %}
                {% assign replacement_title = replacement_lookup.title %}
                {% if replacement_url == discontinued_raw and replacement_lookup.url != blank %}
                  {% assign replacement_url = replacement_lookup.url %}
                {% endif %}
              {% endif %}
            {% endif %}

            {% if replacement_url != blank %}
              <p>
                Replaced with
                <a href="{{ replacement_url }}">
                  {% if replacement_title != blank %}
                    {{ replacement_title }}
                  {% else %}
                    {{ replacement_url }}
                  {% endif %}
                </a>
              </p>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Discontinued Product",
  "settings": [
    {
      "type": "textarea",
      "id": "discontinued_text",
      "label": "Discontinued Text",
      "default": "This product has been discontinued."
    },
    {
      "type": "image_picker",
      "id": "discontinued_img",
      "label": "Discontinued Image"
    }
  ],
  "presets": [
    {
      "category": "Custom",
      "name": "Discontinued Product"
    }
  ]
}
{% endschema %}
