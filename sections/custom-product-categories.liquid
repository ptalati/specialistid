{{ 'custom-product-categories.css' | asset_url | stylesheet_tag }}

<div class="product-categories-section">
  <div class="product-categories-inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-categories-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="product-categories-grid">
      {%- for block in section.blocks -%}
        <div class="product-category-item" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link }}" class="product-category-image-link">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                srcset="{{ block.settings.image | image_url: width: 150 }} 150w,
                        {{ block.settings.image | image_url: width: 200 }} 200w,
                        {{ block.settings.image | image_url: width: 400 }} 400w"
                sizes="(max-width: 640px) 50vw, (max-width: 991px) 30vw, 15vw"
                alt="{{ block.settings.label | escape }}"
                loading="lazy"
                width="400"
                height="314"
              />
            {%- elsif block.settings.image_url != blank -%}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ block.settings.label | escape }}"
                loading="lazy"
              />
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
          <a href="{{ block.settings.link }}" class="product-category-label">
            {{ block.settings.label }}
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Categories",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Categories"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "External image URL (fallback)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "label": "Badge Holders"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Lanyards"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Badge Reels"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Badge Buddies"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Luggage Tags"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Programmable Cards"
          }
        }
      ]
    }
  ]
}
{% endschema %}
