        },
        "text_cLgrxR": {
          "type": "text",
          "settings": {
            "text": "<p>Designed by Specialist ID in collaboration with Top Jewelers, this custom piece features a diamond-studded dual swivel lobster claw attachment system engineered to move seamlessly between form and function.<br/><br/>At 27.5 inches, it can be worn as a traditional statement chain, adapted for single slot-punch or double-ended credential formats, or styled as a luxury wallet chain or chain accessory.<br/><br/>The result is a convertible access piece built for real-world VIP environments without sacrificing the visual impact of the chain itself.<br/><br/></p>",
            "text_style": "body"
          }
        },
        "button_CD4J6m": {
