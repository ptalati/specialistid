      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div id=\"request-pricing\" style=\"scroll-margin-top: 80px; max-width: 760px; margin: 0 auto; text-align: center;\">\n<h2 style=\"font-family: Poppins, sans-serif; font-size: 34px; line-height: 1.15; font-weight: 600; color: #3A3A3C; margin: 0 0 16px 0;\">\nRequest pricing, availability, or a private consultation.\n</h2>\n\n<div style=\"font-family: Rubik, sans-serif; font-size: 16px; line-height: 1.7; color: #3A3A3C; margin: 0 0 22px 0;\">\nSpecialist ID will review fit, timing, credential format, and any concierge requirements directly.\n</div>\n\n<a href=\"/pages/contact-us\"\nstyle=\"display: inline-block; background: #F5911F; color: #FFFFFF; text-decoration: none; font-family: 'Open Sans', sans-serif; font-size: 15px; font-weight: 700; padding: 14px 22px; border-radius: 6px; margin-bottom: 14px;\">\nRequest Pricing &amp; Concierge Details\n</a>\n\n<div style=\"font-family: Rubik, sans-serif; font-size: 14px; line-height: 1.6; color: #6B6B6B;\">\nPrivate inquiry only. Custom commissions available.\n</div>\n</div>",
