{%- comment -%}
  Custom desktop navigation — replaces Meteor Menu app block.
  Driven by Shopify's native menu linklist (section.settings.menu).

  Dropdown style is auto-detected per top-level item by URL pattern:
    • Child links containing /collections/ or /products/ → image-tile mega menu
    • All other child links                              → simple text list

  Images (tile style only) — resolved by parsing the URL handle:
    1. collection.metafields.custom.nav_image  (file_reference, set per collection)
    2. Fallback: collection.image / product.featured_image

  Works regardless of whether links are HTTP, collection_link, or product_link type.

  Usage: {% render 'custom-nav-desktop', menu: section.settings.menu %}
{%- endcomment -%}

{%- assign nav_menu = menu | default: linklists['main-menu'] -%}

<ul class="custom-nav__bar" role="menubar" aria-label="Main navigation">
  {%- for link in nav_menu.links -%}

    {%- comment -%} Detect dropdown style by URL pattern — works for HTTP and native link types {%- endcomment -%}
    {%- assign dropdown_style = 'list' -%}
    {%- for childlink in link.links -%}
      {%- if childlink.url contains '/collections/' or childlink.url contains '/products/' -%}
        {%- assign dropdown_style = 'tiles' -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    <li class="custom-nav__item" role="none">
      <a
        href="{{ link.url }}"
        class="custom-nav__link"
        role="menuitem"
        tabindex="0"
        {%- if link.links != blank %}
          aria-haspopup="true"
          aria-expanded="false"
        {%- endif %}
        {%- if link.current %} aria-current="page"{% endif %}
      >
        {{- link.title | escape -}}
        {%- if link.links != blank -%}
          <svg
            width="20" height="20" viewBox="0 0 20 20"
            xmlns="http://www.w3.org/2000/svg"
            class="custom-nav__caret"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M10 14a.997.997 0 0 1-.707-.293l-5-5a.999.999 0 1 1 1.414-1.414l4.293 4.293 4.293-4.293a.999.999 0 1 1 1.414 1.414l-5 5a.997.997 0 0 1-.707.293z" fill="currentColor"/>
          </svg>
        {%- endif -%}
      </a>

      {%- if link.links != blank -%}
        <div
          class="custom-nav__dropdown{% if dropdown_style == 'list' %} custom-nav__dropdown--list{% endif %}"
          role="menu"
          aria-label="{{ link.title | escape }} submenu"
          tabindex="-1"
        >
          <div class="custom-nav__dropdown-inner">

            {%- if dropdown_style == 'tiles' -%}

              {%- for childlink in link.links -%}
                {%- assign nav_img = blank -%}

                {%- if childlink.type == 'collection_link' -%}
                  {%- comment -%} Native collection link — use object directly {%- endcomment -%}
                  {%- assign nav_img = childlink.object.metafields.custom.nav_image -%}
                  {%- if nav_img == blank -%}{%- assign nav_img = childlink.object.image -%}{%- endif -%}

                {%- elsif childlink.type == 'product_link' -%}
                  {%- comment -%} Native product link — use object directly {%- endcomment -%}
                  {%- assign nav_img = childlink.object.metafields.custom.nav_image -%}
                  {%- if nav_img == blank -%}{%- assign nav_img = childlink.object.featured_image -%}{%- endif -%}

                {%- elsif childlink.url contains '/collections/' -%}
                  {%- comment -%} HTTP collection link — look up by handle from URL {%- endcomment -%}
                  {%- assign col_handle = childlink.url | split: '/collections/' | last | split: '?' | first | split: '#' | first -%}
                  {%- assign col_obj = collections[col_handle] -%}
                  {%- if col_obj -%}
                    {%- assign nav_img = col_obj.metafields.custom.nav_image -%}
                    {%- if nav_img == blank -%}{%- assign nav_img = col_obj.image -%}{%- endif -%}
                  {%- endif -%}

                {%- elsif childlink.url contains '/products/' -%}
                  {%- comment -%} HTTP product link — look up by handle from URL {%- endcomment -%}
                  {%- assign prod_handle = childlink.url | split: '/products/' | last | split: '?' | first | split: '#' | first -%}
                  {%- assign prod_obj = all_products[prod_handle] -%}
                  {%- if prod_obj -%}
                    {%- assign nav_img = prod_obj.metafields.custom.nav_image -%}
                    {%- if nav_img == blank -%}{%- assign nav_img = prod_obj.featured_image -%}{%- endif -%}
                  {%- endif -%}
                {%- endif -%}

                <a
                  href="{{ childlink.url }}"
                  class="custom-nav__tile"
                  role="menuitem"
                  tabindex="-1"
                  {%- if childlink.current %} aria-current="page"{% endif %}
                >
                  <div
                    class="custom-nav__tile-img{% if nav_img == blank %} custom-nav__tile-img--placeholder{% endif %}"
                    aria-hidden="true"
                    {%- if nav_img != blank %}
                      style="background-image: url('{{ nav_img | image_url: width: 200 }}')"
                    {%- endif %}
                  ></div>
                  <span class="custom-nav__tile-label">{{ childlink.title | escape }}</span>
                </a>
              {%- endfor -%}

            {%- else -%}

              {%- for childlink in link.links -%}
                <a
                  href="{{ childlink.url }}"
                  class="custom-nav__list-link"
                  role="menuitem"
                  tabindex="-1"
                  {%- if childlink.current %} aria-current="page"{% endif %}
                >
                  {{- childlink.title | escape -}}
                </a>
              {%- endfor -%}

            {%- endif -%}

          </div>
        </div>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
